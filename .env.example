# Copy to .env next to docker-compose.yml, fill in, chmod 600.
# Secrets source: `pass sessionhelper/*`

# Postgres (used by both the postgres container and DATA_API's DATABASE_URL)
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://ovp:changeme@postgres:5432/ovp_data_api

# S3-compatible object storage
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ovp-dataset-dev

# Shared across every OVP service in this deployment.
# `pass sessionhelper/shared-secret`
SHARED_SECRET=

# Bind address (default 127.0.0.1:8001, set to 0.0.0.0:8001 in Docker)
# BIND_ADDR=127.0.0.1:8001
